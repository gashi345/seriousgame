<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Serious Game - Diagnostic de service</title>

<style>
:root{
  --font-sans: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  --color-text-primary:#111827;
}

*{box-sizing:border-box;margin:0;padding:0}

body{
  font-family:var(--font-sans);
  color:var(--color-text-primary);
  background:#050510;
  overflow-x:hidden;
}

button{
  font-family:inherit;
  -webkit-tap-highlight-color:transparent;
}

.sg{
  width:100%;
  max-width:960px;
  margin:0 auto;
  padding:1rem 12px 2rem;
}

.hero{
  border-radius:22px;
  padding:26px;
  margin-bottom:1.2rem;
  background:#1A0033;
}

.hero-tag{
  display:inline-block;
  background:rgba(255,255,255,0.12);
  color:#E879F9;
  font-size:10px;
  padding:4px 12px;
  border-radius:20px;
  margin-bottom:12px;
}

.hero-title{
  font-size:clamp(20px,4vw,26px);
  color:#fff;
  margin-bottom:8px;
}

.hero-desc{
  font-size:13px;
  color:rgba(255,255,255,0.75);
  margin-bottom:16px;
}

.objs{
  display:grid;
  grid-template-columns:repeat(auto-fit,minmax(160px,1fr));
  gap:8px;
}

.obj{
  border-radius:12px;
  padding:10px;
}

.obj-txt{font-size:12px;color:#fff}

.metho{
  border-radius:22px;
  padding:20px;
  margin-bottom:1.2rem;
  background:#0A0A1A;
}

.metho-title{
  color:#fff;
  margin-bottom:14px;
}

.controls{
  display:flex;
  gap:10px;
  margin-bottom:1rem;
}

.btn-main{
  flex:1;
  padding:13px;
  cursor:pointer;
  border-radius:14px;
  border:2px solid #7C3AED;
  color:#E879F9;
  background:#0D001A;
}

.btn-sec{
  padding:13px;
  cursor:pointer;
  border-radius:14px;
  border:1px solid #444;
  color:#aaa;
  background:transparent;
}

.status{
  border-radius:12px;
  padding:12px;
  margin-bottom:1rem;
  text-align:center;
  background:#111;
  color:#aaa;
}

.status.lit{
  background:#1A0033;
  color:#E879F9;
}

.grid{
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(200px,1fr));
  gap:14px;
}

.cw{
  perspective:1000px;
  min-height:340px;
}

.ci{
  position:relative;
  width:100%;
  min-height:340px;
  transform-style:preserve-3d;
  transition:transform 0.6s;
}

.ci.fl{transform:rotateY(180deg)}

.face{
  position:absolute;
  inset:0;
  backface-visibility:hidden;
  border-radius:16px;
  overflow:hidden;
}

.fback{
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:50px;
  color:#fff;
}

.ffront{
  transform:rotateY(180deg);
  background:#fff;
  padding:12px;
  overflow:auto;
}

.acc-body{display:none}
.acc-body.show{display:block}

.footer-count{
  text-align:center;
  color:#aaa;
  margin-top:10px;
}

@media(max-width:640px){
  .controls{flex-direction:column}
  .grid{grid-template-columns:1fr}
}
</style>
</head>

<body>

<div class="sg">

<div class="hero">
  <div class="hero-tag">SERIOUS GAME</div>
  <div class="hero-title">Diagnostic de service</div>
  <div class="hero-desc">Simulation immersive de gestion d’équipe sous tension</div>
</div>

<div class="status" id="st">Appuyez pour distribuer les rôles</div>

<div class="controls">
  <button class="btn-main" id="db" onclick="drawNext()">Distribuer</button>
  <button class="btn-sec" onclick="newDraw()">Reset</button>
</div>

<div class="grid" id="grid"></div>
<div class="footer-count" id="ft"></div>

</div>

<script>
const CARDS = [
  {name:"Directrice",text:"Valide le plan"},
  {name:"Manager",text:"Anime la réunion"},
  {name:"Résistant",text:"Freine le projet"},
  {name:"Expert",text:"Propose solutions"},
  {name:"Nouveau",text:"Observe tout"}
];

let order=[],idx=0,rev=0;

function shuffle(a){
  return a.sort(()=>Math.random()-0.5);
}

function buildGrid(){
  const g=document.getElementById('grid');
  g.innerHTML='';
  CARDS.forEach((c,i)=>{
    const w=document.createElement('div');
    w.className='cw';
    w.id='w'+(i+1);

    w.innerHTML=`
    <div class="ci" id="ci${i+1}">
      <div class="face fback" style="background:#7C3AED">${i+1}</div>
      <div class="face ffront">
        <b>${c.name}</b><br>${c.text}
      </div>
    </div>`;

    g.appendChild(w);
  });
}

document.addEventListener('click',function(e){
  const card=e.target.closest('.ci');
  if(!card)return;
  if(!card.classList.contains('fl')){
    card.classList.add('fl');
    rev++;
    updateFooter();
  }
});

function drawNext(){
  if(idx>=CARDS.length){
    setStatus('Tous distribués');
    return;
  }

  const cur=order[idx];
  setStatus('Joueur '+cur);
  idx++;
  updateFooter();
}

function newDraw(){
  idx=0;
  rev=0;
  order=shuffle([1,2,3,4,5]);
  buildGrid();
  setStatus('Nouveau tirage');
  updateFooter();
}

function setStatus(t){
  document.getElementById('st').textContent=t;
}

function updateFooter(){
  document.getElementById('ft').textContent=
    idx+" distribué(s) · "+rev+" retourné(s)";
}

order=shuffle([1,2,3,4,5]);
buildGrid();
</script>

</body>
</html>
